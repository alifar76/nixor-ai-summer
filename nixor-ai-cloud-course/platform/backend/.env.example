# Copy to .env (gitignored). The platform acts through a service principal.
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=          # service principal app id
AZURE_CLIENT_SECRET=      # service principal secret — TREAT AS A MASTER KEY
AZURE_LOCATION=swedencentral
INVITE_REDIRECT_URL=https://your-course-site.example.com/welcome

# Magic-link signing (Claude Code will use this when it builds auth)
SESSION_SIGNING_KEY=change-me
