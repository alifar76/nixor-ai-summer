# ----- Auth -----
# Long random string used to sign login tokens. Generate with: openssl rand -hex 32
SESSION_SIGNING_KEY=change-me-to-a-long-random-string
SESSION_TTL_HOURS=168
# Optional: require this shared code at signup to gatekeep your cohort. Leave blank to allow open signup.
SIGNUP_ACCESS_CODE=

# ----- Instructor bootstrap (creates an instructor account on first boot) -----
INSTRUCTOR_EMAIL=
INSTRUCTOR_PASSWORD=

# ----- Database -----
DATABASE_URL=sqlite:////data/lab_platform.db

# ----- Azure AI Foundry (the in-app chatbot) -----
# From your Foundry/Azure OpenAI resource. The key stays server-side only.
AZURE_OPENAI_ENDPOINT=https://YOUR-FOUNDRY-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5-5
AZURE_OPENAI_API_VERSION=2024-10-21
# Built-in chatbot default model id (must exist in /api/ai/models catalog)
CHAT_DEFAULT_MODEL_ID=gpt-5.5

# ----- 6-model Azure Foundry catalog (for student apps + terminal) -----
# Verified deployable set for this course:
#   gpt-5.5, grok-4.3, DeepSeek-V4-Pro, mistral-medium-3-5, FLUX.2-pro, sora-2
AZURE_FOUNDRY_ENDPOINT=https://YOUR-FOUNDRY-RESOURCE.cognitiveservices.azure.com/
AZURE_FOUNDRY_API_KEY=
MODEL_GPT55_DEPLOYMENT=oai-gpt55
MODEL_GROK43_DEPLOYMENT=xai-grok43
MODEL_DEEPSEEK_V4_PRO_DEPLOYMENT=ds-v4pro
MODEL_MISTRAL_MEDIUM_35_DEPLOYMENT=mstr-med35
MODEL_FLUX2_PRO_DEPLOYMENT=bfl-flux2
MODEL_SORA2_DEPLOYMENT=oai-sora2
# Optional full JSON override for /api/ai/models.
AI_MODEL_CATALOG_JSON=

# ----- Server-side one-click deploy (Session 3 "Deploy to Azure") -----
# Service principal the platform uses to run `az webapp up` into each student's
# resource group on their behalf (students never run `az login`). Create with:
#   az ad sp create-for-rbac --name nixor-deployer --role Contributor \
#     --scopes /subscriptions/<SUB_ID>
# Leave blank to disable the deploy endpoint (it returns a clear 503).
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
# Web app runtime/SKU for student deploys. F1 is free; B1 stays warm for demo day.
DEPLOY_RUNTIME=PYTHON:3.11
DEPLOY_SKU=F1
DEPLOY_TIMEOUT_SEC=600

# ----- Per-student workspace containers -----
WORKSPACE_DRIVER=local
WORKSPACE_IMAGE=nixor-workspace:latest
WORKSPACE_CPUS=1.0
WORKSPACE_MEMORY_MB=1024
WORKSPACE_NETWORK=bridge
WORKSPACE_HOME=/home/student
DOCKER_HOST=
LOCAL_WORKSPACE_ROOT=/home/site/workspaces
# LOCAL_WORKSPACE_TEMPLATE_DIR=/absolute/path/to/student-app
TERMINAL_REQUIRE_NON_ROOT=true
LOCAL_SANDBOX_UID=1000
LOCAL_SANDBOX_GID=1000
TERMINAL_BLOCK_DANGEROUS_COMMANDS=true
# Regex OR-pattern list (advanced). Keep defaults unless you need custom policy.
# TERMINAL_BLOCK_PATTERNS=(^|\\s)rm\\s+-rf\\s+--no-preserve-root\\s+/(\\s|$)|(^|\\s)rm\\s+-rf\\s+/(\\s|$)

# ----- CORS (lock to your domain in production) -----
CORS_ORIGINS=*
